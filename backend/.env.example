# Backend configuration. Copy to `.env` to override defaults.

# Port the API listens on.
PORT=4000

# Comma-separated allowed CORS origins (the frontend URL).
CORS_ORIGINS=http://localhost:3000

# --- Claude / candidate sourcing agent (optional) --------------------------
# Enables live web sourcing + scoring via Claude (web_search + web_fetch tools).
# If missing, /api/candidates falls back to the mock dataset — safe to run
# locally with no key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Google Sheets (optional) ----------------------------------------------
# If any of these are missing, /api/sheets/add-candidate logs a warning and
# returns a mock success instead of writing to a sheet — safe to run locally.

# Service account email, e.g. wayco-recruiter@my-project.iam.gserviceaccount.com
GOOGLE_SHEETS_CLIENT_EMAIL=

# Service account private key. Keep the literal "\n" escapes from the JSON key
# file — the app converts them back to real newlines at runtime.
GOOGLE_SHEETS_PRIVATE_KEY=

# The ID from the sheet URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Optional: the tab/sheet name to append rows to. Defaults to "Candidates".
GOOGLE_SHEETS_SHEET_NAME=Candidates
